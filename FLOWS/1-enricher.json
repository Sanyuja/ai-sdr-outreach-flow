    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// robust parse + normalize keys\nconst input = $input.item.json || {};\n\nconst normalized = {};\nfor (const k of Object.keys(input)) {\n  normalized[k.trim()] = input[k];\n}\n\nfunction findOrg(obj) {\n  const candidates = ['Organization_name', 'Organization name', 'Organization', 'organization_name', 'organization'];\n  for (const c of candidates) {\n    if (Object.prototype.hasOwnProperty.call(obj, c) && obj[c]) return obj[c];\n  }\n  for (const k of Object.keys(obj)) {\n    if (k.trim() === 'Organization_name' && obj[k]) return obj[k];\n  }\n  return '';\n}\n\nlet raw = '';\nif (input?.choices?.[0]) {\n  raw = input.choices[0].message?.content ?? input.choices[0].text ?? '';\n} else if (input?.message?.content || input?.message?.text) {\n  raw = input.message.content ?? input.message.text;\n} else if (input?.output?.[0]) {\n  raw = input.output[0].content ?? input.output[0].text ?? '';\n} else {\n  for (const k of Object.keys(input)) {\n    if (typeof input[k] === 'string' && input[k].trim()) { raw = input[k]; break; }\n    if (input[k] && typeof input[k] === 'object') {\n      const nested = input[k].content ?? input[k].text;\n      if (typeof nested === 'string' && nested.trim()) { raw = nested; break; }\n    }\n  }\n}\n\nlet parsed = {};\nif (raw) {\n  const fenceMatch = raw.match(/```(?:json)?\\s*([\\s\\S]*?)\\s*```/);\n  const toParse = fenceMatch ? fenceMatch[1].trim() : raw.trim();\n  try { parsed = JSON.parse(toParse); } catch { try { parsed = JSON.parse(raw); } catch { parsed = {}; } }\n}\n\nif (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {\n  parsed = {};\n}\n\nlet orgName = parsed.Organization_name || parsed['Organization name'] || '';\nif (!orgName) orgName = findOrg(normalized) || findOrg(input) || '';\n\nconst out = Object.assign({}, parsed);\nout.Organization_name = orgName;\n\nreturn { json: out };\n"
      },
